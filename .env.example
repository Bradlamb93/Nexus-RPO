# ===========================================
# First Choice Connect - Environment Variables
# ===========================================

# ─── Application ─────────────────────────────────────────────────────
VITE_APP_TITLE="First Choice Connect"
VITE_API_URL=http://localhost:3001/api
PORT=3001
NODE_ENV=production

# ─── Database (PostgreSQL) ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexus_rpo
DB_USER=nexus
DB_PASSWORD=nexus_dev

# ─── Authentication ──────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=10

# ─── CORS ────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
