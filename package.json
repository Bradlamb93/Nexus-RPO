{
  "name": "first-choice-connect",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:server": "node server/index.js",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "build": "vite build",
    "preview": "vite preview",
    "db:migrate": "node server/migrations/run.js",
    "db:seed": "node server/seeds/run.js",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "start": "NODE_ENV=production node server/index.js",
    "deploy": "./scripts/deploy.sh",
    "deploy:build": "./scripts/deploy.sh build",
    "deploy:stop": "./scripts/deploy.sh stop",
    "deploy:status": "./scripts/deploy.sh status",
    "deploy:logs": "./scripts/deploy.sh logs",
    "deploy:clean": "./scripts/deploy.sh clean"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "concurrently": "^8.2.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.12.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "terser": "^5.46.1",
    "vite": "^5.1.0"
  }
}
